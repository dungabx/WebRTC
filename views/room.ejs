<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Phòng <%= roomId %> - WebRTC Video Call</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>
  <input type="hidden" id="room-id" value="<%= roomId %>">
  <input type="hidden" id="usr-nickname" value="<%= user.nickname %>">
  <input type="hidden" id="usr-avatar" value="<%= user.avatar %>">

  <div class="room-container">
    <!-- Thanh trên -->
    <div class="top-bar">
      <div class="top-bar-left">
        <a href="/" class="back-btn" title="Về trang chủ"><i class="fas fa-arrow-left"></i></a>
        <div class="room-info">
          <span class="room-label">Phòng:</span>
          <span class="room-code" id="room-code"><%= roomId %></span>
          <button class="copy-btn" id="copy-btn" title="Sao chép mã phòng"><i class="fas fa-copy"></i></button>
        </div>
      </div>
      <div class="top-bar-right" style="display: flex; gap: 15px; align-items: center;">
        <div class="call-timer" id="call-timer" style="display: none; align-items: center; gap: 6px; font-weight: 600; font-family: monospace; font-size: 16px; background: var(--glass); padding: 5px 12px; border-radius: 20px; border: 1px solid var(--border);">
          <i class="fas fa-clock text-primary"></i> <span id="timer-text">00:00</span>
        </div>
        <div class="connection-status" id="connection-status">
          <span class="status-dot"></span>
          <span class="status-text">Đang chờ...</span>
        </div>
      </div>
    </div>

    <!-- Khu vực chính -->
    <div class="main-content" id="main-content">
      <div class="video-area">
        <!-- Video đối phương -->
        <div class="video-container remote-container" id="remote-container">
          <video id="remote-video" autoplay playsinline></video>
          <div class="video-placeholder" id="remote-placeholder">
            <div class="placeholder-content">
              <div class="pulse-ring"></div>
              <i class="fas fa-user-plus placeholder-icon"></i>
              <h3>Đang chờ người tham gia...</h3>
              <p>Chia sẻ mã phòng <strong><%= roomId %></strong> để bắt đầu</p>
              <button class="btn btn-small btn-outline" id="share-link-btn">
                <i class="fas fa-share-alt"></i> Sao chép liên kết
              </button>
            </div>
          </div>
          <div class="video-label" id="remote-label" style="display:none; align-items:center; gap:8px;">
            <img id="remote-avatar" src="" style="width:24px; height:24px; border-radius:50%; object-fit:cover; display: none;">
            <span id="remote-nickname">Khách ẩn danh</span>
          </div>
        </div>
        <!-- Video bản thân (PIP) -->
        <div class="video-container local-container" id="local-container">
          <video id="local-video" autoplay playsinline muted></video>
          <div class="video-label" style="display:flex; align-items:center; gap:8px;">
            <img src="<%= user.avatar %>" style="width:24px; height:24px; border-radius:50%; object-fit:cover;">
            <span><%= user.nickname %> (Bạn)</span>
          </div>
        </div>
      </div>

      <!-- Bảng chat -->
      <div class="chat-panel" id="chat-panel">
        <div class="chat-header">
          <h3><i class="fas fa-comment-dots"></i> Trò chuyện</h3>
          <button class="chat-close-btn" id="chat-close-btn"><i class="fas fa-times"></i></button>
        </div>
        <div class="chat-messages" id="chat-messages">
          <div class="chat-empty">
            <i class="fas fa-comments"></i>
            <p>Chưa có tin nhắn</p>
          </div>
        </div>
        <div class="chat-input-area">
          <input type="text" id="chat-input" placeholder="Nhập tin nhắn..." autocomplete="off">
          <button class="chat-send-btn" id="chat-send-btn"><i class="fas fa-paper-plane"></i></button>
        </div>
      </div>
    </div>

    <!-- Thanh điều khiển -->
    <div class="controls-bar">
      <div class="controls">
        <button class="control-btn" id="btn-mic" title="Tắt/Bật mic">
          <i class="fas fa-microphone"></i>
        </button>
        <button class="control-btn" id="btn-camera" title="Tắt/Bật camera">
          <i class="fas fa-video"></i>
        </button>
        <button class="control-btn" id="btn-screen" title="Chia sẻ màn hình">
          <i class="fas fa-desktop"></i>
        </button>
        <button class="control-btn" id="btn-emoji" title="Thả tim">
          <i class="fas fa-heart text-primary"></i>
        </button>
        <button class="control-btn" id="btn-chat" title="Mở chat">
          <i class="fas fa-comment-dots"></i>
          <span class="chat-badge" id="chat-badge" style="display:none;">0</span>
        </button>
        <button class="control-btn control-btn-danger" id="btn-leave" title="Rời phòng">
          <i class="fas fa-phone-slash"></i>
        </button>
      </div>
    </div>
  </div>

  <!-- Thông báo toast -->
  <div class="toast-container" id="toast-container"></div>

  <script src="/socket.io/socket.io.js"></script>
  <script src="/js/stream.js"></script>
</body>
</html>
