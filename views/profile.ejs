<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hồ sơ của tôi - Dũng WebRTC</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        .profile-container {
            max-width: 600px; margin: 50px auto; padding: 30px;
            background: var(--surface); border-radius: var(--radius);
            box-shadow: var(--shadow);
        }
        .profile-header {
            display: flex; align-items: center; gap: 20px;
            margin-bottom: 30px; padding-bottom: 20px; border-bottom: 1px solid #333;
        }
        .profile-avatar { width: 100px; height: 100px; border-radius: 50%; object-fit: cover; border: 3px solid var(--primary); }
        .form-group { margin-bottom: 15px; }
        .form-group label { display: block; margin-bottom: 5px; color: var(--text-secondary); }
        .form-group input { 
            width: 100%; padding: 12px; border-radius: 8px;
            border: 1px solid #444; background: #222; color: #fff;
        }
        .history-section { margin-top: 40px; padding-top: 20px; border-top: 1px solid #333; }
        .history-table { width: 100%; border-collapse: collapse; margin-top: 15px; font-size: 14px; }
        .history-table th, .history-table td { padding: 12px; text-align: left; border-bottom: 1px solid #333; }
        .history-table th { color: var(--accent-l); font-weight: 600; }
        .history-table tr:hover { background: var(--glass2); }
        .empty-history { text-align: center; color: var(--dim); padding: 20px; font-style: italic; }
    </style>
</head>
<body>
    <div class="container">
        <header class="header">
            <div class="logo">
                <i class="fas fa-video text-primary"></i> Dũng WebRTC
            </div>
            <div class="header-actions">
                <a href="/" class="btn btn-secondary"><i class="fas fa-home"></i> Trang chủ</a>
            </div>
        </header>

        <div class="profile-container">
            <div class="profile-header">
                <img src="<%= user.avatar %>" alt="Avatar" class="profile-avatar">
                <div>
                    <h2>Hồ Sơ Của Bạn</h2>
                    <p class="text-secondary">Tài khoản: <%= user.username %></p>
                </div>
            </div>

            <form action="/profile" method="POST" enctype="multipart/form-data">
                <div class="form-group">
                    <label>Biệt danh hiển thị (Nickname)</label>
                    <input type="text" name="nickname" value="<%= user.nickname %>" required>
                </div>
                <div class="form-group">
                    <label>Tải ảnh đại diện mới</label>
                    <input type="file" name="avatar" accept="image/*">
                </div>
                <button type="submit" class="btn btn-primary" style="margin-top: 20px; width:100%;">
                    Lưu Thay Đổi
                </button>
            </form>

            <!-- Lịch sử cuộc gọi -->
            <div class="history-section">
                <h3><i class="fas fa-history text-primary"></i> Lịch Sử Cuộc Gọi</h3>
                <% if (typeof history !== 'undefined' && history.length > 0) { %>
                    <table class="history-table">
                        <thead>
                            <tr>
                                <th>Ngày giờ (UTC)</th>
                                <th>Mã phòng</th>
                                <th>Thời lượng</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% history.forEach(item => { 
                                const dateObj = new Date(item.created_at + 'Z'); // Bổ sung Z để hiểu là UTC
                                const dateStr = dateObj.toLocaleString('vi-VN');
                                const min = Math.floor(item.duration_seconds / 60);
                                const sec = item.duration_seconds % 60;
                                const timeStr = min > 0 ? `${min} phút ${sec} giây` : `${sec} giây`;
                            %>
                            <tr>
                                <td><%= dateStr %></td>
                                <td><span style="color:var(--accent); font-weight: bold;"><%= item.room_code %></span></td>
                                <td><%= timeStr %></td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                <% } else { %>
                    <div class="empty-history">
                        <i class="fas fa-box-open" style="font-size: 24px; margin-bottom: 10px; display:block;"></i> 
                        Chưa có cuộc gọi nào được ghi nhận.
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</body>
</html>
